model AuditLog {
  auditLogId String @id @default(uuid()) @db.Uuid

  tenantId String @db.Uuid

  // Actor — null means automated system action; soft ref → User in system DB
  actorId   String?        @db.Uuid
  actorType AuditActorType @default(SYSTEM)

  // What happened
  action String // e.g. "member.invited", "settings.updated"

  // What was affected
  resourceType String? // e.g. "TenantMember", "TenantSetting"
  resourceId   String?

  // Extra context
  metadata  Json? // { before: {}, after: {}, extra: {} }
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now()) @db.Timestamp

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@index([tenantId])
  @@index([actorId])
  @@index([action])
  @@index([resourceType])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// Shared across system and tenant databases
enum AuditActorType {
  USER
  SYSTEM
}

// Tenant Enums
enum TenantStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
  DELETED
  ARCHIVED
}

// Tenant Invitation Enums
enum TenantInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

// Tenant Member Enums
enum TenantMemberRole {
  OWNER
  ADMIN
  USER
}

enum TenantMemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

// Domain Enums
enum DomainStatus {
  ACTIVE
  INACTIVE
  PENDING
  VERIFIED
}

// Subscription Enums
enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIALING
}

// Payment Enums
enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
  EXPIRED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  IYZICO
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
  OTHER
}

enum TransactionType {
  PAYMENT
  REFUND
  CHARGEBACK
  PAYOUT
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Payment {
  paymentId         String          @id @default(uuid()) @db.Uuid
  userId            String?         @db.Uuid // soft ref → User in system DB
  tenantId          String?         @db.Uuid
  provider          PaymentProvider
  providerPaymentId String?         @db.VarChar

  amount        Decimal        @db.Decimal(12, 2)
  currency      String         @db.VarChar(3)
  status        PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?

  description String? @db.Text
  metadata    Json?   @db.JsonB

  customerEmail  String? @db.VarChar
  customerName   String? @db.VarChar
  customerPhone  String? @db.VarChar
  billingAddress Json?   @db.JsonB

  refundedAmount Decimal? @db.Decimal(12, 2)
  failureCode    String?  @db.VarChar
  failureMessage String?  @db.Text

  paidAt      DateTime? @db.Timestamp
  cancelledAt DateTime? @db.Timestamp
  refundedAt  DateTime? @db.Timestamp
  expiresAt   DateTime? @db.Timestamp
  createdAt   DateTime  @default(now()) @db.Timestamp
  updatedAt   DateTime  @updatedAt @db.Timestamp
  deletedAt   DateTime? @db.Timestamp

  tenant       Tenant?              @relation(fields: [tenantId], references: [tenantId], onDelete: SetNull)
  transactions PaymentTransaction[]

  @@index([userId])
  @@index([tenantId])
  @@index([provider])
  @@index([providerPaymentId])
  @@index([status])
  @@index([currency])
  @@index([createdAt])
  @@map("payments")
}

model PaymentTransaction {
  transactionId         String          @id @default(uuid()) @db.Uuid
  paymentId             String          @db.Uuid
  provider              PaymentProvider
  providerTransactionId String?         @db.VarChar

  type   TransactionType   @default(PAYMENT)
  status TransactionStatus @default(PENDING)

  amount   Decimal  @db.Decimal(12, 2)
  currency String   @db.VarChar(3)
  fee      Decimal? @db.Decimal(12, 2)
  net      Decimal? @db.Decimal(12, 2)

  providerResponse Json?   @db.JsonB
  errorCode        String? @db.VarChar
  errorMessage     String? @db.Text

  parentTransactionId String? @db.Uuid

  ipAddress String? @db.VarChar(45)
  userAgent String? @db.Text

  processedAt DateTime? @db.Timestamp
  createdAt   DateTime  @default(now()) @db.Timestamp
  updatedAt   DateTime  @updatedAt @db.Timestamp

  payment            Payment              @relation(fields: [paymentId], references: [paymentId], onDelete: Cascade)
  parentTransaction  PaymentTransaction?  @relation("RefundRelation", fields: [parentTransactionId], references: [transactionId], onDelete: SetNull)
  refundTransactions PaymentTransaction[] @relation("RefundRelation")

  @@index([paymentId])
  @@index([provider])
  @@index([providerTransactionId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([parentTransactionId])
  @@map("payment_transactions")
}

generator client {
  provider   = "prisma-client-js"
  accelerate = "true"
  output     = "../client"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  tenantId     String       @id @default(uuid()) @db.Uuid
  name         String       @db.VarChar
  description  String?      @db.Text
  tenantStatus TenantStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @db.Timestamp
  updatedAt    DateTime     @updatedAt @db.Timestamp
  deletedAt    DateTime?    @db.Timestamp

  domains      TenantDomain[]
  members      TenantMember[]
  invitations  TenantInvitation[]
  payments     Payment[]
  subscription TenantSubscription?
  settings     TenantSetting[]
  auditLogs    AuditLog[]

  @@map("tenants")
}

model TenantDomain {
  tenantDomainId    String       @id @default(uuid()) @db.Uuid
  tenantId          String       @db.Uuid
  domain            String       @unique @db.VarChar
  isPrimary         Boolean      @default(false)
  domainStatus      DomainStatus @default(PENDING)
  verificationToken String?      @db.VarChar
  verifiedAt        DateTime?    @db.Timestamp
  createdAt         DateTime     @default(now()) @db.Timestamp
  updatedAt         DateTime     @updatedAt @db.Timestamp

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_domains")
}

model TenantInvitation {
  invitationId    String                 @id @default(uuid()) @db.Uuid
  tenantId        String                 @db.Uuid
  email           String                 @db.VarChar
  invitedByUserId String                 @db.Uuid // soft ref → User in system DB
  memberRole      TenantMemberRole       @default(USER)
  token           String                 @unique @db.VarChar
  status          TenantInvitationStatus @default(PENDING)
  expiresAt       DateTime               @db.Timestamp
  createdAt       DateTime               @default(now()) @db.Timestamp
  updatedAt       DateTime               @updatedAt @db.Timestamp

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
  @@index([token])
  @@map("tenant_invitations")
}

model TenantMember {
  tenantMemberId String             @id @default(uuid()) @db.Uuid
  tenantId       String             @db.Uuid
  userId         String             @db.Uuid // soft ref → User in system DB
  memberRole     TenantMemberRole   @default(USER)
  memberStatus   TenantMemberStatus @default(ACTIVE)
  createdAt      DateTime           @default(now()) @db.Timestamp
  updatedAt      DateTime           @updatedAt @db.Timestamp
  deletedAt      DateTime?          @db.Timestamp

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_members")
}

model TenantSetting {
  tenantId  String   @db.Uuid
  key       String   @db.VarChar
  value     String   @db.Text
  group     String   @default("general") @db.VarChar
  type      String   @default("string") @db.VarChar
  createdAt DateTime @default(now()) @db.Timestamp
  updatedAt DateTime @updatedAt @db.Timestamp

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@id([tenantId, key])
  @@index([tenantId, group])
  @@map("tenant_settings")
}

model TenantSubscription {
  subscriptionId     String             @id @default(uuid()) @db.Uuid
  tenantId           String             @db.Uuid
  planId             String             @db.Uuid // soft ref → SubscriptionPlan in system DB
  status             SubscriptionStatus @default(ACTIVE)
  billingInterval    BillingInterval    @default(MONTHLY)
  currentPeriodStart DateTime           @db.Timestamp
  currentPeriodEnd   DateTime           @db.Timestamp
  trialEndsAt        DateTime?          @db.Timestamp
  cancelledAt        DateTime?          @db.Timestamp
  createdAt          DateTime           @default(now()) @db.Timestamp
  updatedAt          DateTime           @updatedAt @db.Timestamp

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@unique([tenantId])
  @@index([planId])
  @@index([status])
  @@map("tenant_subscriptions")
}
