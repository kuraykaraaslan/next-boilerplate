model AuditLog {
  auditLogId   String         @id @default(uuid()) @db.Uuid

  tenantId     String         @db.Uuid

  // Actor — null means automated system action; soft ref → User in system DB
  actorId      String?        @db.Uuid
  actorType    AuditActorType @default(SYSTEM)

  // What happened
  action       String         // e.g. "member.invited", "settings.updated"

  // What was affected
  resourceType String?        // e.g. "TenantMember", "TenantSetting"
  resourceId   String?

  // Extra context
  metadata     Json?          // { before: {}, after: {}, extra: {} }
  ipAddress    String?
  userAgent    String?

  createdAt    DateTime       @default(now()) @db.Timestamp

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@index([tenantId])
  @@index([actorId])
  @@index([action])
  @@index([resourceType])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
