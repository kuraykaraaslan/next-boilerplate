// User Enums
enum UserRole {
  GUEST
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Tenant Enums
enum TenantStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
  DELETED
  ARCHIVED
}

// Tenant Member Enums
enum TenantMemberRole {
  OWNER
  ADMIN
  USER
}

enum TenantMemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

// Domain Enums
enum DomainStatus {
  ACTIVE
  INACTIVE
  PENDING
  VERIFIED
}

// User Security Enums
enum OTPMethod {
  EMAIL
  SMS
  TOTP_APP
}

// User Preferences Enums
enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum Language {
  EN
  ES
  FR
  DE
  CN
  JP
}

enum DateFormat {
  DD_MM_YYYY
  MM_DD_YYYY
}

enum TimeFormat {
  H24
  H12
}

enum FirstDayOfWeek {
  MON
  SUN
}

// Social Account Enums
enum SocialAccountProvider {
  google
  apple
  facebook
  github
  linkedin
  microsoft
  twitter
  slack
  tiktok
  wechat
  autodesk
}

// Session Enums
enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// Payment Enums
enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
  EXPIRED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  IYZICO
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
  OTHER
}

enum TransactionType {
  PAYMENT
  REFUND
  CHARGEBACK
  PAYOUT
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Payment {
  paymentId         String          @id @default(uuid()) @db.Uuid
  userId            String?         @db.Uuid
  tenantId          String?         @db.Uuid
  provider          PaymentProvider
  providerPaymentId String?         @db.VarChar // External payment ID from provider (e.g., pi_xxx for Stripe)

  amount   Decimal @db.Decimal(12, 2)
  currency String  @db.VarChar(3) // ISO 4217 currency code

  status        PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?

  description String? @db.Text
  metadata    Json?   @db.JsonB // Additional data from provider or custom fields

  // Customer info (for guest checkouts or reference)
  customerEmail String? @db.VarChar
  customerName  String? @db.VarChar
  customerPhone String? @db.VarChar

  // Billing address
  billingAddress Json? @db.JsonB

  // Refund tracking
  refundedAmount Decimal? @db.Decimal(12, 2)

  // Error tracking
  failureCode    String? @db.VarChar
  failureMessage String? @db.Text

  // Timestamps
  paidAt      DateTime? @db.Timestamp
  cancelledAt DateTime? @db.Timestamp
  refundedAt  DateTime? @db.Timestamp
  expiresAt   DateTime? @db.Timestamp
  createdAt   DateTime  @default(now()) @db.Timestamp
  updatedAt   DateTime  @updatedAt @db.Timestamp
  deletedAt   DateTime? @db.Timestamp

  // Relations
  user         User?                @relation(fields: [userId], references: [userId], onDelete: SetNull)
  tenant       Tenant?              @relation(fields: [tenantId], references: [tenantId], onDelete: SetNull)
  transactions PaymentTransaction[]

  @@index([userId])
  @@index([tenantId])
  @@index([provider])
  @@index([providerPaymentId])
  @@index([status])
  @@index([currency])
  @@index([createdAt])
  @@map("payments")
}

model PaymentTransaction {
  transactionId         String          @id @default(uuid()) @db.Uuid
  paymentId             String          @db.Uuid
  provider              PaymentProvider
  providerTransactionId String?         @db.VarChar // External transaction ID from provider

  type   TransactionType   @default(PAYMENT)
  status TransactionStatus @default(PENDING)

  amount   Decimal  @db.Decimal(12, 2)
  currency String   @db.VarChar(3) // ISO 4217 currency code
  fee      Decimal? @db.Decimal(12, 2) // Provider fee
  net      Decimal? @db.Decimal(12, 2) // Amount after fee

  // Raw response from provider
  providerResponse Json? @db.JsonB

  // Error tracking
  errorCode    String? @db.VarChar
  errorMessage String? @db.Text

  // For refunds - reference to original transaction
  parentTransactionId String? @db.Uuid

  // IP and user agent for fraud detection
  ipAddress String? @db.VarChar(45) // IPv6 max length
  userAgent String? @db.Text

  // Timestamps
  processedAt DateTime? @db.Timestamp
  createdAt   DateTime  @default(now()) @db.Timestamp
  updatedAt   DateTime  @updatedAt @db.Timestamp

  // Relations
  payment            Payment              @relation(fields: [paymentId], references: [paymentId], onDelete: Cascade)
  parentTransaction  PaymentTransaction?  @relation("RefundRelation", fields: [parentTransactionId], references: [transactionId], onDelete: SetNull)
  refundTransactions PaymentTransaction[] @relation("RefundRelation")

  @@index([paymentId])
  @@index([provider])
  @@index([providerTransactionId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([parentTransactionId])
  @@map("payment_transactions")
}

generator client {
  provider   = "prisma-client-js"
  accelerate = "true"
  output     = "../client"
}

datasource db {
  provider = "postgresql"
}

model Setting {
  tenantId  String    @default("00000000-0000-0000-0000-000000000000") @db.Uuid
  key       String    @db.VarChar
  value     String    @db.Text
  group     String    @default("general") @db.VarChar
  type      String    @default("string") @db.VarChar
  createdAt DateTime  @default(now()) @db.Timestamp
  updatedAt DateTime? @updatedAt @db.Timestamp

  @@id([tenantId, key])
  @@index([tenantId, group])
  @@map("settings")
}

model Tenant {
  tenantId     String       @id @default(uuid()) @db.Uuid
  name         String       @db.VarChar
  description  String?      @db.Text
  tenantStatus TenantStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @db.Timestamp
  updatedAt    DateTime     @updatedAt @db.Timestamp
  deletedAt    DateTime?    @db.Timestamp

  domains  TenantDomain[]
  members  TenantMember[]
  payments Payment[]

  @@map("tenants")
}

model TenantDomain {
  tenantDomainId    String       @id @default(uuid()) @db.Uuid
  tenantId          String       @db.Uuid
  domain            String       @unique @db.VarChar
  isPrimary         Boolean      @default(false)
  domainStatus      DomainStatus @default(PENDING)
  verificationToken String?      @db.VarChar
  verifiedAt        DateTime?    @db.Timestamp
  createdAt         DateTime     @default(now()) @db.Timestamp
  updatedAt         DateTime     @updatedAt @db.Timestamp

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_domains")
}

model TenantMember {
  tenantMemberId String             @id @default(uuid()) @db.Uuid
  tenantId       String             @db.Uuid
  userId         String             @db.Uuid
  memberRole     TenantMemberRole   @default(USER)
  memberStatus   TenantMemberStatus @default(ACTIVE)
  createdAt      DateTime           @default(now()) @db.Timestamp
  updatedAt      DateTime           @updatedAt @db.Timestamp
  deletedAt      DateTime?          @db.Timestamp

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_members")
}

model User {
  userId     String     @id @default(uuid()) @db.Uuid
  email      String     @unique @db.VarChar
  phone      String?    @db.VarChar
  password   String     @db.VarChar
  userRole   UserRole   @default(USER)
  userStatus UserStatus @default(ACTIVE)
  createdAt  DateTime   @default(now()) @db.Timestamp
  updatedAt  DateTime   @updatedAt @db.Timestamp
  deletedAt  DateTime?  @db.Timestamp

  profile        UserProfile?
  security       UserSecurity?
  preferences    UserPreferences?
  socialAccounts UserSocialAccount[]
  sessions       UserSession[]
  tenantMembers  TenantMember[]
  payments       Payment[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

model UserPreferences {
  userPreferencesId  String         @id @default(uuid()) @db.Uuid
  userId             String         @unique @db.Uuid
  theme              Theme          @default(SYSTEM)
  language           Language       @default(EN)
  emailNotifications Boolean        @default(true)
  smsNotifications   Boolean        @default(false)
  pushNotifications  Boolean        @default(true)
  newsletter         Boolean        @default(true)
  timezone           String         @default("UTC") @db.VarChar
  dateFormat         DateFormat     @default(DD_MM_YYYY)
  timeFormat         TimeFormat     @default(H24)
  firstDayOfWeek     FirstDayOfWeek @default(MON)
  createdAt          DateTime       @default(now()) @db.Timestamp
  updatedAt          DateTime       @updatedAt @db.Timestamp

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("user_preferences")
}

model UserProfile {
  userProfileId  String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @db.Uuid
  name           String?  @db.VarChar
  biography      String?  @db.Text
  profilePicture String?  @db.VarChar
  headerImage    String?  @db.VarChar
  socialLinks    Json     @default("[]") @db.JsonB
  createdAt      DateTime @default(now()) @db.Timestamp
  updatedAt      DateTime @updatedAt @db.Timestamp

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSecurity {
  userSecurityId      String      @id @default(uuid()) @db.Uuid
  userId              String      @unique @db.Uuid
  otpMethods          OTPMethod[] @default([])
  otpSecret           String?     @db.VarChar
  otpBackupCodes      Json        @default("[]") @db.JsonB
  lastLoginAt         DateTime?   @db.Timestamp
  lastLoginIp         String?     @db.VarChar
  lastLoginDevice     String?     @db.VarChar
  failedLoginAttempts Int         @default(0)
  lockedUntil         DateTime?   @db.Timestamp
  createdAt           DateTime    @default(now()) @db.Timestamp
  updatedAt           DateTime    @updatedAt @db.Timestamp

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("user_securities")
}

model UserSession {
  userSessionId     String        @id @default(uuid()) @db.Uuid
  userId            String        @db.Uuid
  accessToken       String        @db.Text
  refreshToken      String        @db.Text
  deviceFingerprint String?       @db.VarChar
  userAgent         String?       @db.Text
  ipAddress         String?       @db.VarChar
  sessionStatus     SessionStatus @default(ACTIVE)
  otpVerifyNeeded   Boolean       @default(false)
  sessionExpiry     DateTime      @db.Timestamp
  createdAt         DateTime      @default(now()) @db.Timestamp
  updatedAt         DateTime      @updatedAt @db.Timestamp

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([accessToken])
  @@index([refreshToken])
  @@map("user_sessions")
}

model UserSocialAccount {
  userSocialAccountId String                @id @default(uuid()) @db.Uuid
  userId              String                @db.Uuid
  provider            SocialAccountProvider
  providerId          String                @db.VarChar
  accessToken         String?               @db.Text
  refreshToken        String?               @db.Text
  profilePicture      String?               @db.VarChar
  createdAt           DateTime              @default(now()) @db.Timestamp
  updatedAt           DateTime              @updatedAt @db.Timestamp

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("user_social_accounts")
}
