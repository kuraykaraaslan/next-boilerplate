model TenantMember {
  tenantMemberId String             @id @default(uuid()) @db.Uuid
  tenantId       String             @db.Uuid
  userId         String             @db.Uuid
  memberRole     TenantMemberRole   @default(USER)
  memberStatus   TenantMemberStatus @default(ACTIVE)
  createdAt      DateTime           @default(now()) @db.Timestamp
  updatedAt      DateTime           @updatedAt @db.Timestamp
  deletedAt      DateTime?          @db.Timestamp

  tenant Tenant @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_members")
}
