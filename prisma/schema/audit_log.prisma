model AuditLog {
  auditLogId   String         @id @default(uuid()) @db.Uuid

  // Scope — null means system-level event
  tenantId     String?        @db.Uuid

  // Actor — null means automated system action
  actorId      String?        @db.Uuid
  actorType    AuditActorType @default(SYSTEM)

  // What happened
  action       String         // e.g. "member.invited", "settings.updated"

  // What was affected
  resourceType String?        // e.g. "TenantMember", "Setting", "Subscription"
  resourceId   String?        // UUID or identifier of the affected record

  // Extra context
  metadata     Json?          // { before: {}, after: {}, extra: {} }
  ipAddress    String?
  userAgent    String?

  createdAt    DateTime       @default(now()) @db.Timestamp

  @@index([tenantId])
  @@index([actorId])
  @@index([action])
  @@index([resourceType])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
