model PaymentTransaction {
  transactionId           String            @id @default(uuid()) @db.Uuid
  paymentId               String            @db.Uuid
  provider                PaymentProvider
  providerTransactionId   String?           @db.VarChar // External transaction ID from provider

  type                    TransactionType   @default(PAYMENT)
  status                  TransactionStatus @default(PENDING)

  amount                  Decimal           @db.Decimal(12, 2)
  currency                String            @db.VarChar(3) // ISO 4217 currency code
  fee                     Decimal?          @db.Decimal(12, 2) // Provider fee
  net                     Decimal?          @db.Decimal(12, 2) // Amount after fee

  // Raw response from provider
  providerResponse        Json?             @db.JsonB

  // Error tracking
  errorCode               String?           @db.VarChar
  errorMessage            String?           @db.Text

  // For refunds - reference to original transaction
  parentTransactionId     String?           @db.Uuid

  // IP and user agent for fraud detection
  ipAddress               String?           @db.VarChar(45) // IPv6 max length
  userAgent               String?           @db.Text

  // Timestamps
  processedAt             DateTime?         @db.Timestamp
  createdAt               DateTime          @default(now()) @db.Timestamp
  updatedAt               DateTime          @updatedAt @db.Timestamp

  // Relations
  payment                 Payment           @relation(fields: [paymentId], references: [paymentId], onDelete: Cascade)
  parentTransaction       PaymentTransaction? @relation("RefundRelation", fields: [parentTransactionId], references: [transactionId], onDelete: SetNull)
  refundTransactions      PaymentTransaction[] @relation("RefundRelation")

  @@index([paymentId])
  @@index([provider])
  @@index([providerTransactionId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([parentTransactionId])
  @@map("payment_transactions")
}
