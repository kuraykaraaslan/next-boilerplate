model AuditLog {
  auditLogId   String         @id @default(uuid()) @db.Uuid

  // Actor — null means automated system action
  actorId      String?        @db.Uuid
  actorType    AuditActorType @default(SYSTEM)

  // What happened
  action       String         // e.g. "user.created", "settings.updated"

  // What was affected
  resourceType String?        // e.g. "User", "Setting", "SubscriptionPlan"
  resourceId   String?

  // Extra context
  metadata     Json?          // { before: {}, after: {}, extra: {} }
  ipAddress    String?
  userAgent    String?

  createdAt    DateTime       @default(now()) @db.Timestamp

  actor User? @relation(fields: [actorId], references: [userId], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([resourceType])
  @@map("audit_logs")
}
