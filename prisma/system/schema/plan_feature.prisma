model PlanFeature {
  featureId String          @id @default(uuid()) @db.Uuid
  planId    String          @db.Uuid
  key       String          @db.VarChar
  label     String          @db.VarChar
  type      PlanFeatureType @default(BOOLEAN)
  value     String          @db.VarChar // "true"/"false" for BOOLEAN, "10", "100", "-1" (unlimited) for LIMIT
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now()) @db.Timestamp
  updatedAt DateTime        @updatedAt @db.Timestamp

  plan SubscriptionPlan @relation(fields: [planId], references: [planId], onDelete: Cascade)

  @@unique([planId, key])
  @@index([planId])
  @@map("plan_features")
}
