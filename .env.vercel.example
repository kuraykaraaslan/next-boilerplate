# =============================================================================
# Vercel deployment — example environment
# =============================================================================
# Copy these into Vercel → Project → Settings → Environment Variables
# (Production, and Preview if you use preview deploys). Replace every
# <placeholder>. Only the keys in "Required" must be set; the rest are optional
# provider integrations — see .env / modules/env/env.schema.*.ts for the full list.
#
# Domains assumed below: wildcard *.next-boilerplate.kuray.dev, root tenant at
# system.next-boilerplate.kuray.dev (and the bare apex).

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APPLICATION_NAME=MyApp
NEXT_PUBLIC_APPLICATION_HOST=https://system.next-boilerplate.kuray.dev
NEXT_PUBLIC_API_URL=https://system.next-boilerplate.kuray.dev

# ── Database (Neon / Postgres) — REQUIRED ────────────────────────────────────
# DATABASE_URL          → pooled (PgBouncer) connection, used for app runtime.
# DATABASE_URL_UNPOOLED → direct connection, used for migrations, schema sync,
#                         and heavy cross-tenant jobs. Falls back to DATABASE_URL.
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?channel_binding=require&sslmode=require
DATABASE_URL_UNPOOLED=postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<db>?sslmode=require

# ── Redis (use a TCP-reachable managed Redis, e.g. Upstash) ──────────────────
REDIS_URL=rediss://<user>:<password>@<host>:<port>

# ── Tenancy ──────────────────────────────────────────────────────────────────
TENANCY_MODE=domain
TENANT_DEFAULT_SUBDOMAIN=system
TENANT_WILDCARD_DOMAIN=next-boilerplate.kuray.dev
NEXT_PUBLIC_TENANT_WILDCARD_DOMAIN=next-boilerplate.kuray.dev
TENANT_PATH_PREFIX=t
TENANT_CACHE_TTL=300

# ── Auth secrets — REQUIRED (generate with: openssl rand -hex 32) ────────────
ACCESS_TOKEN_SECRET=<generate-32-byte-hex>
REFRESH_TOKEN_SECRET=<generate-32-byte-hex>
CSRF_SECRET=<generate-32-byte-hex>
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
# Encrypts tenant settings at rest (recommended in production)
SETTINGS_ENCRYPTION_KEY=<generate-32-byte-hex>

# ── Passkeys / WebAuthn ──────────────────────────────────────────────────────
# RP ID must be the registrable parent so passkeys work across every subdomain.
WEBAUTHN_RP_ID=next-boilerplate.kuray.dev
WEBAUTHN_ORIGIN=https://system.next-boilerplate.kuray.dev

# ── Background jobs & cron ───────────────────────────────────────────────────
# Set true on a long-running worker; leave false on serverless functions.
ENABLE_BACKGROUND_JOBS=false
# Shared secret for Vercel Cron → /api/cron/* routes (Authorization: Bearer ...)
CRON_SECRET=<generate-32-byte-hex>

# ── Observability (optional) ─────────────────────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# METRICS_ENABLED=false
# METRICS_SECRET=

# ── Mail (optional — pick a provider; defaults to SMTP) ──────────────────────
MAIL_PROVIDER=smtp
MAIL_FROM=noreply@next-boilerplate.kuray.dev
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# ── Optional integrations ────────────────────────────────────────────────────
# Storage (S3), Web Push (VAPID), OAuth/SSO providers, SMS, payments and AI
# providers are all optional. See .env and modules/env/env.schema.*.ts for the
# complete set of keys and add only the ones you use.
