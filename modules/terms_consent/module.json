{
  "$schema": "../module.schema.json",
  "id": "terms_consent",
  "name": "Terms & Consent",
  "description": "Legal agreements + consent. Versioned, immutable, hash-stamped agreement documents (terms of use, privacy/KVKK, distance-selling, pre-information, refund policy, cookie, custom) with an append-only acceptance ledger. Reusable agreements record version+hash on acceptance; order-specific documents (distance-selling/pre-information) are rendered per order and stored verbatim. Also keeps the cookie-consent banner + per-purpose consent ledger. Checkout integration enforces required agreement acceptance before payment. Data export/erasure stays with tenant_export.",
  "version": "1.0.0",
  "icon": "fas fa-file-contract",
  "tags": [
    "platform",
    "legal",
    "agreements",
    "terms",
    "consent",
    "gdpr",
    "kvkk",
    "compliance"
  ],
  "priority": 47,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "redis",
      "common",
      "audit_log",
      "setting"
    ]
  },
  "settingKeys": [
    "consentBannerEnabled",
    "consentPolicyVersion",
    "consentBannerTitle",
    "consentBannerMessage",
    "consentPurposes",
    "checkoutRequiredAgreements",
    "legalSellerName",
    "legalSellerAddress",
    "legalSellerTaxOffice",
    "legalSellerTaxId",
    "legalSellerMersis",
    "legalSellerEmail",
    "legalSellerPhone"
  ],
  "settings": {
    "keys": "TERMS_CONSENT_KEYS"
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/terms_consent",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "agreements",
      "label": "Agreements",
      "href": "/admin/terms",
      "icon": "fas fa-file-contract",
      "group": "Configuration",
      "order": 10,
      "scope": "tenant"
    },
    {
      "id": "consent",
      "label": "Consent",
      "href": "/admin/consent",
      "icon": "fas fa-cookie-bite",
      "group": "Configuration",
      "order": 20,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/consent",
      "component": "terms_consent/ui/consent.page"
    },
    {
      "path": "/admin/terms",
      "component": "terms_consent/ui/terms.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/agreements/[agreementId]",
      "handler": "terms_consent/server/agreements-agreement-id.route"
    },
    {
      "path": "/api/agreements/[agreementId]/versions/[versionId]/publish",
      "handler": "terms_consent/server/agreements-agreement-id-versions-version-id-publish.route"
    },
    {
      "path": "/api/agreements/[agreementId]/versions",
      "handler": "terms_consent/server/agreements-agreement-id-versions.route"
    },
    {
      "path": "/api/agreements/accept",
      "handler": "terms_consent/server/agreements-accept.route"
    },
    {
      "path": "/api/agreements/acceptances",
      "handler": "terms_consent/server/agreements-acceptances.route"
    },
    {
      "path": "/api/agreements",
      "handler": "terms_consent/server/agreements.route"
    },
    {
      "path": "/api/consent/config",
      "handler": "terms_consent/server/consent-config.route"
    },
    {
      "path": "/api/consent/records",
      "handler": "terms_consent/server/consent-records.route"
    },
    {
      "path": "/api/consent",
      "handler": "terms_consent/server/consent.route"
    }
  ]
}
