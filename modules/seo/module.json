{
  "$schema": "../module.schema.json",
  "id": "seo",
  "name": "SEO Metadata",
  "description": "Polymorphic SEO metadata (title, description, Open Graph, canonical, noIndex) attachable to any entity type via entityType + entityId pair.",
  "version": "1.0.0",
  "icon": "fas fa-search",
  "tags": [
    "seo",
    "metadata"
  ],
  "priority": 35,
  "dependencies": {
    "requires": [
      "db",
      "redis"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/seo",
  "license": "CC-BY-NC-ND-4.0",
  "apiRoutes": [
    {
      "path": "/api/seo/[entityType]/[entityId]",
      "handler": "seo/server/seo-entity-type-entity-id.route"
    },
    {
      "path": "/api/seo/web-vitals",
      "handler": "seo/server/seo-web-vitals.route"
    }
  ]
}
