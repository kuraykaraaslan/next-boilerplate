{
  "$schema": "../module.schema.json",
  "id": "gift_card",
  "name": "Gift Card",
  "description": "Prepaid gift cards: issue (single + bulk) hash-protected codes, track redeemable balance, and redeem into a user's wallet. Redemption posts a wallet credit in the card's currency; supports partial redemption, void, admin balance adjustment, and an expiry sweep. Builds on wallet (credit) and payment (purchase-backed issuing).",
  "version": "1.0.0",
  "icon": "fas fa-gift",
  "tags": [
    "billing",
    "commerce",
    "gift-card",
    "wallet"
  ],
  "priority": 49,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "logger",
      "common",
      "redis",
      "wallet",
      "payment",
      "webhook",
      "tenant_subscription"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/gift_card",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "gift-cards",
      "label": "Gift Cards",
      "href": "/admin/gift-cards",
      "icon": "fas fa-gift",
      "group": "Commerce",
      "workspace": "commerce",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/gift-cards/[giftCardId]",
      "component": "gift_card/ui/gift-cards-gift-card-id.page"
    },
    {
      "path": "/admin/gift-cards",
      "component": "gift_card/ui/gift-cards.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/gift-cards/[giftCardId]",
      "handler": "gift_card/server/gift-cards-gift-card-id.route"
    },
    {
      "path": "/api/gift-cards/[giftCardId]/transactions",
      "handler": "gift_card/server/gift-cards-gift-card-id-transactions.route"
    },
    {
      "path": "/api/gift-cards/balance",
      "handler": "gift_card/server/gift-cards-balance.route"
    },
    {
      "path": "/api/gift-cards/redeem",
      "handler": "gift_card/server/gift-cards-redeem.route"
    },
    {
      "path": "/api/gift-cards",
      "handler": "gift_card/server/gift-cards.route"
    },
    {
      "path": "/api/cron/gift-card-expiry",
      "handler": "gift_card/server/cron-gift-card-expiry.route"
    }
  ]
}
