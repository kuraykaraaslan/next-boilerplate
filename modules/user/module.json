{
  "$schema": "../module.schema.json",
  "id": "user",
  "name": "User",
  "description": "Core user CRUD: create, find, update, deactivate. Foundation for every auth and tenancy flow.",
  "version": "1.0.0",
  "icon": "fas fa-user",
  "tags": [
    "identity",
    "core"
  ],
  "priority": 10,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "logger",
      "common"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/user",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "platform-users",
      "label": "Users",
      "href": "/admin/users",
      "icon": "fas fa-users",
      "group": "Platform",
      "workspace": "system",
      "order": 10,
      "scope": "system"
    }
  ],
  "routes": [
    {
      "path": "/admin/users/[userId]",
      "component": "user/ui/users-user-id.page"
    },
    {
      "path": "/admin/users",
      "component": "user/ui/users.page"
    },
    {
      "path": "/admin/me",
      "component": "user/ui/me.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/users/[userId]/impersonation-sessions",
      "handler": "user/server/users-user-id-impersonation-sessions.route"
    },
    {
      "path": "/api/users/[userId]",
      "handler": "user/server/users-user-id.route"
    },
    {
      "path": "/api/users/[userId]/tenants",
      "handler": "user/server/users-user-id-tenants.route"
    },
    {
      "path": "/api/users",
      "handler": "user/server/users.route"
    }
  ]
}
