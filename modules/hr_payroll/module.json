{
  "$schema": "../module.schema.json",
  "id": "hr_payroll",
  "name": "Payroll",
  "description": "Tenant-scoped payroll: payroll runs, payslips and salary components.",
  "version": "1.0.0",
  "icon": "fas fa-money-check-dollar",
  "tags": [
    "payroll",
    "hr",
    "erp"
  ],
  "priority": 60,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "redis",
      "logger",
      "setting"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/hr_payroll",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "payroll-runs",
      "label": "Payroll Runs",
      "href": "/admin/payroll/runs",
      "icon": "fas fa-money-check-dollar",
      "group": "Payroll",
      "workspace": "hr",
      "order": 40,
      "scope": "tenant"
    },
    {
      "id": "payroll-payslips",
      "label": "Payslips",
      "href": "/admin/payroll/payslips",
      "icon": "fas fa-file-invoice-dollar",
      "group": "Payroll",
      "workspace": "hr",
      "order": 50,
      "scope": "tenant"
    },
    {
      "id": "payroll-settings",
      "label": "Payroll Settings",
      "href": "/admin/payroll/settings",
      "icon": "fas fa-gear",
      "group": "Configuration",
      "workspace": "hr",
      "order": 90,
      "scope": "tenant"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/payroll/runs",
      "handler": "hr_payroll/server/payroll-runs.route"
    },
    {
      "path": "/api/payroll/runs/[runId]",
      "handler": "hr_payroll/server/payroll-runs-run-id.route"
    },
    {
      "path": "/api/payroll/runs/[runId]/process",
      "handler": "hr_payroll/server/payroll-runs-run-id-process.route"
    },
    {
      "path": "/api/payroll/runs/[runId]/pay",
      "handler": "hr_payroll/server/payroll-runs-run-id-pay.route"
    },
    {
      "path": "/api/payroll/payslips",
      "handler": "hr_payroll/server/payroll-payslips.route"
    },
    {
      "path": "/api/payroll/payslips/[payslipId]",
      "handler": "hr_payroll/server/payroll-payslips-payslip-id.route"
    },
    {
      "path": "/api/payroll/payslips/[payslipId]/issue",
      "handler": "hr_payroll/server/payroll-payslips-payslip-id-issue.route"
    },
    {
      "path": "/api/payroll/payslips/[payslipId]/pay",
      "handler": "hr_payroll/server/payroll-payslips-payslip-id-pay.route"
    },
    {
      "path": "/api/payroll/payslips/[payslipId]/lines",
      "handler": "hr_payroll/server/payroll-payslips-payslip-id-lines.route"
    },
    {
      "path": "/api/payroll/payslips/[payslipId]/lines/[payslipLineId]",
      "handler": "hr_payroll/server/payroll-payslips-payslip-id-lines-line-id.route"
    },
    {
      "path": "/api/payroll/components",
      "handler": "hr_payroll/server/payroll-components.route"
    },
    {
      "path": "/api/payroll/components/[componentId]",
      "handler": "hr_payroll/server/payroll-components-component-id.route"
    }
  ],
  "routes": [
    {
      "path": "/admin/payroll/runs",
      "component": "hr_payroll/ui/payroll-runs.page"
    },
    {
      "path": "/admin/payroll/runs/[runId]",
      "component": "hr_payroll/ui/payroll-runs-run-id.page"
    },
    {
      "path": "/admin/payroll/runs/settings",
      "component": "hr_payroll/ui/payroll-runs-settings.page"
    },
    {
      "path": "/admin/payroll/payslips",
      "component": "hr_payroll/ui/payroll-payslips.page"
    },
    {
      "path": "/admin/payroll/payslips/[payslipId]",
      "component": "hr_payroll/ui/payroll-payslips-payslip-id.page"
    },
    {
      "path": "/admin/payroll/payslips/settings",
      "component": "hr_payroll/ui/payroll-payslips-settings.page"
    },
    {
      "path": "/admin/payroll/settings",
      "component": "hr_payroll/ui/payroll-settings.page"
    }
  ]
}
