{
  "$schema": "../module.schema.json",
  "id": "tenant_subscription",
  "name": "Tenant Subscription",
  "description": "Tenant subscription state, plan + feature key resolution, grace period, expiry job.",
  "version": "1.0.0",
  "icon": "fas fa-credit-card",
  "tags": [
    "tenant",
    "billing"
  ],
  "priority": 24,
  "dependencies": {
    "requires": [
      "db",
      "tenant",
      "payment",
      "redis",
      "env"
    ]
  },
  "settings": {
    "keys": "SUBSCRIPTION_KEYS"
  },
  "settingKeys": [
    "SUBSCRIPTION_KEYS",
    "FEATURE_KEYS"
  ],
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/tenant_subscription",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "subscription",
      "label": "Subscription",
      "href": "/admin/subscription",
      "icon": "fas fa-credit-card",
      "group": "Management",
      "workspace": "crm",
      "order": 10,
      "scope": "tenant"
    },
    {
      "id": "subscription-admin-list",
      "label": "Subscriptions",
      "href": "/admin/subscriptions",
      "icon": "fas fa-rectangle-list",
      "group": "Management",
      "workspace": "crm",
      "order": 11,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/subscription",
      "component": "tenant_subscription/ui/subscription.page"
    },
    {
      "path": "/admin/subscriptions",
      "component": "tenant_subscription/ui/subscriptions.page"
    },
    {
      "path": "/admin/subscription/[subscriptionId]",
      "component": "tenant_subscription/ui/subscription-subscription-id.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/subscription/confirm",
      "handler": "tenant_subscription/server/subscription-confirm.route"
    },
    {
      "path": "/api/subscription/features",
      "handler": "tenant_subscription/server/subscription-features.route"
    },
    {
      "path": "/api/subscription/grace-period",
      "handler": "tenant_subscription/server/subscription-grace-period.route"
    },
    {
      "path": "/api/subscription/pay/3ds-callback",
      "handler": "tenant_subscription/server/subscription-pay-3ds-callback.route"
    },
    {
      "path": "/api/subscription/pay",
      "handler": "tenant_subscription/server/subscription-pay.route"
    },
    {
      "path": "/api/subscription/payment-intent/confirm",
      "handler": "tenant_subscription/server/subscription-payment-intent-confirm.route"
    },
    {
      "path": "/api/subscription/payment-intent",
      "handler": "tenant_subscription/server/subscription-payment-intent.route"
    },
    {
      "path": "/api/subscription/quote",
      "handler": "tenant_subscription/server/subscription-quote.route"
    },
    {
      "path": "/api/subscription",
      "handler": "tenant_subscription/server/subscription.route"
    },
    {
      "path": "/api/subscription/admin",
      "handler": "tenant_subscription/server/subscription-admin.route"
    },
    {
      "path": "/api/subscription/admin/[subscriptionId]",
      "handler": "tenant_subscription/server/subscription-admin-subscription-id.route"
    },
    {
      "path": "/api/subscription/admin/[subscriptionId]/renew",
      "handler": "tenant_subscription/server/subscription-admin-subscription-id-renew.route"
    },
    {
      "path": "/api/subscription/admin/[subscriptionId]/cancel",
      "handler": "tenant_subscription/server/subscription-admin-subscription-id-cancel.route"
    },
    {
      "path": "/api/subscription/admin/[subscriptionId]/expire",
      "handler": "tenant_subscription/server/subscription-admin-subscription-id-expire.route"
    },
    {
      "path": "/api/subscription/admin/[subscriptionId]/start-grace",
      "handler": "tenant_subscription/server/subscription-admin-subscription-id-start-grace.route"
    },
    {
      "path": "/api/cron/expire-subscriptions",
      "handler": "tenant_subscription/server/cron-expire-subscriptions.route"
    }
  ]
}
