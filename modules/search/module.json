{
  "$schema": "../module.schema.json",
  "id": "search",
  "name": "Search",
  "description": "Tenant-scoped full-text search over arbitrary content. Owning modules push documents (title/body/url/metadata keyed by entityType+entityId); the default PostgreSQL FTS provider ranks results with ts_rank and returns ts_headline snippets. Provider abstraction leaves room for Meilisearch/Elastic. All queries are parameterized and tenant-scoped.",
  "version": "1.0.0",
  "icon": "fas fa-magnifying-glass",
  "tags": [
    "platform",
    "search",
    "full-text"
  ],
  "priority": 55,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "redis",
      "common"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/search",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "search",
      "label": "Search",
      "href": "/admin/search",
      "icon": "fas fa-magnifying-glass",
      "group": "Insights",
      "workspace": "crm",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/search",
      "component": "search/ui/search.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/search/index",
      "handler": "search/server/search-index.route"
    },
    {
      "path": "/api/search",
      "handler": "search/server/search.route"
    }
  ]
}
