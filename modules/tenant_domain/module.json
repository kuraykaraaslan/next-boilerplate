{
  "$schema": "../module.schema.json",
  "id": "tenant_domain",
  "name": "Tenant Domain",
  "description": "Custom domain mapping per tenant + DNS verification (TXT/CNAME challenge).",
  "version": "1.0.0",
  "icon": "fas fa-globe",
  "tags": [
    "tenant",
    "domain",
    "infrastructure"
  ],
  "priority": 23,
  "dependencies": {
    "requires": [
      "db",
      "tenant",
      "env"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/tenant_domain",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "domains",
      "label": "Domains",
      "href": "/admin/domains",
      "icon": "fas fa-globe",
      "group": "Management",
      "workspace": "crm",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/domains",
      "component": "tenant_domain/ui/domains.page"
    },
    {
      "path": "/admin/domains/settings",
      "component": "tenant_domain/ui/domains-settings.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/domains/[domainId]",
      "handler": "tenant_domain/server/domains-domain-id.route"
    },
    {
      "path": "/api/domains/[domainId]/verify",
      "handler": "tenant_domain/server/domains-domain-id-verify.route"
    },
    {
      "path": "/api/domains",
      "handler": "tenant_domain/server/domains.route"
    },
    {
      "path": "/api/cron/dns-recheck",
      "handler": "tenant_domain/server/cron-dns-recheck.route"
    },
    {
      "path": "/api/cron/ssl-health",
      "handler": "tenant_domain/server/cron-ssl-health.route"
    }
  ]
}
