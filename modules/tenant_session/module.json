{
  "$schema": "../module.schema.json",
  "id": "tenant_session",
  "name": "Tenant Security",
  "description": "Session and security settings for tenants",
  "version": "1.0.0",
  "author": "System",
  "icon": "faShield",
  "tags": ["tenant", "security", "session"],
  "enabled": true,
  "priority": 72,
  "dependencies": {
    "requires": ["tenant"]
  },
  "settings": {
    "tabs": [
      {
        "id": "security",
        "label": "Security",
        "icon": "faShield",
        "component": "ui/tenant_session.tenant",
        "order": 50,
        "scope": "tenant",
        "keys": "TENANT_SECURITY_KEYS"
      }
    ]
  },
  "permissions": [
    { "id": "tenant_security.view", "name": "View Security Settings", "group": "security" },
    { "id": "tenant_security.edit", "name": "Edit Security Settings", "group": "security" }
  ]
}
