{
  "$schema": "../module.schema.json",
  "id": "auth",
  "name": "Authentication",
  "description": "Credential auth: login, register, password reset, email verify, OTP, TOTP. Coordinates user, user_session, user_security, notification_mail.",
  "version": "1.0.0",
  "icon": "fas fa-shield-halved",
  "tags": [
    "identity",
    "auth",
    "core"
  ],
  "priority": 15,
  "dependencies": {
    "requires": [
      "user",
      "user_session",
      "user_security",
      "notification_mail",
      "notification_sms",
      "setting",
      "tenant",
      "tenant_invitation",
      "audit_log",
      "webhook",
      "observability",
      "db",
      "env",
      "redis",
      "common"
    ]
  },
  "settings": {
    "keys": "AUTH_KEYS"
  },
  "settingKeys": [
    "AUTH_KEYS",
    "GENERAL_KEYS"
  ],
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/auth",
  "license": "CC-BY-NC-ND-4.0",
  "routes": [
    {
      "path": "/admin/auth/settings",
      "component": "auth/ui/auth-settings.page"
    }
  ]
}
