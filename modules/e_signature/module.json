  "priority": 35,
  "dependencies": {
    "requires": ["db", "env", "user", "user_session", "user_security", "redis", "redis_idempotency", "limiter", "audit_log", "logger"],
    "optional": ["storage", "tenant_setting"]
  },
  "settings": { "keys": "E_SIGNATURE_KEYS" },
  "settingKeys": ["E_SIGNATURE_KEYS"]
}
