{
  "$schema": "../module.schema.json",
  "id": "e_signature",
  "name": "E-Signature & E-Identity",
  "description": "Multi-country e-identity login + e-signature (eIDAS/OIDC4IDA). Pluggable providers (TR Mobil \u0130mza, Smart-ID, BankID, itsme, FranceConnect, eIDAS-nPA, Signicat).",
  "version": "0.1.0",
  "icon": "fas fa-id-card",
  "tags": [
    "auth",
    "identity",
    "signature",
    "eidas"
  ],
  "priority": 35,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "user",
      "user_session",
      "user_security",
      "redis",
      "redis_idempotency",
      "limiter",
      "audit_log",
      "logger"
    ],
    "optional": [
      "storage",
      "setting"
    ]
  },
  "settings": {
    "keys": "E_SIGNATURE_KEYS"
  },
  "settingKeys": [
    "E_SIGNATURE_KEYS"
  ],
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/e_signature",
  "license": "CC-BY-NC-ND-4.0",
  "apiRoutes": [
    {
      "path": "/api/e-signature/settings",
      "handler": "e_signature/server/e-signature-settings.route"
    }
  ],
  "extensionPoints": [
    {
      "id": "esign:provider",
      "kind": "provider",
      "description": "A national e-signature / eID backend. Sandboxed community plugins (the @esign/* family, e.g. @esign/smart_id) contribute their implementation here."
    }
  ]
}
