{
  "$schema": "../module.schema.json",
  "id": "notification_mail",
  "name": "Email Notifications",
  "description": "Email notification system",
  "version": "1.0.0",
  "author": "System",
  "icon": "faEnvelope",
  "tags": ["notification", "email"],
  "enabled": true,
  "priority": 30,
  "settingKeys": [
    "smtpHost", "smtpPort", "smtpUsername", "smtpPassword", "smtpEncryption",
    "fromEmail", "fromName",
    "pushNotificationsEnabled", "vapidPublicKey", "vapidPrivateKey",
    "emailOnNewUser", "emailOnNewComment", "emailOnNewOrder", "emailOnNewContact",
    "slackWebhookUrl", "slackNotificationsEnabled",
    "adminNotificationEmail"
  ],
  "settings": {
    "tabs": [
      { "id": "email", "label": "Email", "icon": "faEnvelope", "component": "ui/notification_mail.settings", "order": 20, "scope": "system" }
    ]
  },
  "permissions": [
    { "id": "email.view", "name": "View Email Settings", "group": "notifications" },
    { "id": "email.send", "name": "Send Emails", "group": "notifications" }
  ]
}
