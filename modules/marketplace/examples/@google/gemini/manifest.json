{
  "id": "google",
  "name": "Google (Gemini)",
  "version": "1.0.0",
  "description": "Google Gemini chat + embeddings provider, contributed into ai:provider — runs sandboxed.",
  "icon": "fas fa-robot",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": ["http", "secrets"],
    "httpAllowlist": ["generativelanguage.googleapis.com"],
    "limits": { "memoryMb": 64, "timeoutMs": 30000, "httpTimeoutMs": 28000, "httpMaxBytes": 4000000 }
  },
  "config": {
    "secrets": [
      { "key": "apiKey", "label": "API Key", "help": "Google AI (Gemini) API key (kept encrypted, used only host-side for signed egress)." }
    ]
  },
  "extensions": [
    {
      "point": "ai:provider",
      "key": "google",
      "metadata": {
        "label": "Google",
        "models": ["gemini-2.0-flash", "gemini-2.0-flash-lite", "gemini-1.5-pro", "gemini-1.5-flash", "gemini-1.5-flash-8b"]
      }
    }
  ]
}
