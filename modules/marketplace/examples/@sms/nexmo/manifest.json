{
  "id": "nexmo",
  "name": "Nexmo (Vonage) SMS",
  "version": "1.0.0",
  "description": "Nexmo / Vonage SMS provider, contributed into sms:provider — sandboxed. Form-encoded REST; the API secret stays host-side.",
  "icon": "fas fa-comment-sms",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": ["http", "settings"],
    "httpAllowlist": ["rest.nexmo.com"],
    "limits": { "memoryMb": 64, "timeoutMs": 20000, "httpTimeoutMs": 18000, "httpMaxBytes": 1000000 }
  },
  "config": {
    "settings": [
      { "key": "nexmoApiKey", "label": "API Key", "help": "Vonage API key." },
      { "key": "nexmoPhoneNumber", "label": "From", "help": "Sender id / phone number." }
    ],
    "secrets": [
      { "key": "nexmoApiSecret", "label": "API Secret", "help": "Vonage API secret; injected host-side, never seen by the plugin." }
    ]
  },
  "extensions": [
    { "point": "sms:provider", "key": "nexmo", "metadata": { "label": "Nexmo" } }
  ]
}
