{
  "id": "kimi",
  "name": "Kimi (Moonshot AI)",
  "version": "1.0.0",
  "description": "Kimi / Moonshot AI chat provider, contributed into ai:provider — runs sandboxed.",
  "icon": "fas fa-robot",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": ["http", "secrets"],
    "httpAllowlist": ["api.moonshot.ai"],
    "limits": { "memoryMb": 64, "timeoutMs": 30000, "httpTimeoutMs": 28000, "httpMaxBytes": 2000000 }
  },
  "extensions": [
    {
      "point": "ai:provider",
      "key": "kimi",
      "metadata": {
        "label": "Kimi (Moonshot)",
        "models": ["kimi-k2-0711-preview", "moonshot-v1-8k", "moonshot-v1-32k", "moonshot-v1-128k"]
      }
    }
  ]
}
