{
  "id": "cloudpayments",
  "name": "CloudPayments Gateway",
  "version": "1.0.0",
  "description": "CloudPayments payment gateway (hosted redirect; card / SBP), contributed into payment:gateway — sandboxed. API secret stays host-side (Basic auth built host-side).",
  "icon": "fas fa-credit-card",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": ["http", "settings"],
    "httpAllowlist": ["api.cloudpayments.ru"],
    "limits": { "memoryMb": 64, "timeoutMs": 30000, "httpTimeoutMs": 28000, "httpMaxBytes": 2000000 }
  },
  "config": {
    "secrets": [
      { "key": "cloudpaymentsApiSecret", "label": "CloudPayments API Secret", "help": "Stored encrypted; used host-side as the Basic-auth password." }
    ],
    "settings": [
      { "key": "cloudpaymentsPublicId", "label": "CloudPayments Public ID" }
    ]
  },
  "extensions": [
    {
      "point": "payment:gateway",
      "key": "cloudpayments",
      "metadata": {
        "label": "CloudPayments",
        "ops": ["getPaymentStatus", "createCheckoutSession"],
        "supportsDirectCardPayment": false,
        "supports3dsCardPayment": false,
        "wallets": [
          { "method": "CARD", "delivery": "HOSTED_REDIRECT" },
          { "method": "SBP", "delivery": "HOSTED_REDIRECT" }
        ]
      }
    }
  ]
}
