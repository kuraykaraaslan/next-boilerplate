{
  "id": "openai",
  "name": "OpenAI",
  "version": "1.0.0",
  "description": "OpenAI (and OpenAI-compatible) chat + embeddings provider, contributed into ai:provider — runs sandboxed.",
  "icon": "fas fa-robot",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": ["http", "secrets"],
    "httpAllowlist": ["api.openai.com"],
    "limits": { "memoryMb": 64, "timeoutMs": 30000, "httpTimeoutMs": 28000, "httpMaxBytes": 4000000 }
  },
  "config": {
    "secrets": [
      { "key": "apiKey", "label": "API Key", "help": "OpenAI API key (kept encrypted, used only host-side for signed egress)." }
    ]
  },
  "extensions": [
    {
      "point": "ai:provider",
      "key": "openai",
      "metadata": {
        "label": "OpenAI",
        "models": ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo", "gpt-4", "gpt-3.5-turbo", "o1", "o1-mini", "o1-preview"]
      }
    }
  ]
}
