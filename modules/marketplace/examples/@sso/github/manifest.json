{
  "id": "github",
  "name": "Github",
  "version": "1.0.0",
  "description": "github social login (OAuth2/OIDC), contributed into auth_sso:provider — sandboxed.",
  "icon": "fab fa-github",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": [
      "http",
      "secrets"
    ],
    "httpAllowlist": [
      "github.com",
      "api.github.com"
    ],
    "limits": {
      "memoryMb": 64,
      "timeoutMs": 30000,
      "httpTimeoutMs": 28000,
      "httpMaxBytes": 2000000
    }
  },
  "config": {
    "secrets": [
      {
        "key": "clientSecret",
        "label": "OAuth Client Secret"
      }
    ]
  },
  "extensions": [
    {
      "point": "auth_sso:provider",
      "key": "github",
      "metadata": {
        "label": "Github",
        "usesPkce": false,
        "secondEmailCall": "https://api.github.com/user/emails",
        "profileMap": {
          "sub": "id",
          "email": "email",
          "name": "name",
          "username": "login",
          "picture": "avatar_url"
        }
      }
    }
  ]
}
