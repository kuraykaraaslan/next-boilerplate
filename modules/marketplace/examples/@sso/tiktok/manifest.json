{
  "id": "tiktok",
  "name": "Tiktok",
  "version": "1.0.0",
  "description": "tiktok social login (OAuth2/OIDC), contributed into auth_sso:provider — sandboxed.",
  "icon": "fab fa-tiktok",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": [
      "http",
      "secrets"
    ],
    "httpAllowlist": [
      "open.tiktokapis.com"
    ],
    "limits": {
      "memoryMb": 64,
      "timeoutMs": 30000,
      "httpTimeoutMs": 28000,
      "httpMaxBytes": 2000000
    }
  },
  "config": {
    "secrets": [
      {
        "key": "clientSecret",
        "label": "OAuth Client Secret"
      }
    ]
  },
  "extensions": [
    {
      "point": "auth_sso:provider",
      "key": "tiktok",
      "metadata": {
        "label": "Tiktok",
        "usesPkce": true,
        "openidFrom": "open_id",
        "profileMap": {
          "sub": "union_id",
          "name": "display_name",
          "picture": "avatar_url"
        }
      }
    }
  ]
}
