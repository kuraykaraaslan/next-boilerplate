{
  "id": "wechat",
  "name": "Wechat",
  "version": "1.0.0",
  "description": "wechat social login (OAuth2/OIDC), contributed into auth_sso:provider — sandboxed.",
  "icon": "fab fa-weixin",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": [
      "http",
      "secrets"
    ],
    "httpAllowlist": [
      "api.weixin.qq.com"
    ],
    "limits": {
      "memoryMb": 64,
      "timeoutMs": 30000,
      "httpTimeoutMs": 28000,
      "httpMaxBytes": 2000000
    }
  },
  "config": {
    "secrets": [
      {
        "key": "clientSecret",
        "label": "OAuth Client Secret"
      }
    ]
  },
  "extensions": [
    {
      "point": "auth_sso:provider",
      "key": "wechat",
      "metadata": {
        "label": "Wechat",
        "usesPkce": false,
        "tokenMethod": "GET",
        "openidFrom": "openid",
        "userinfoAuth": "query",
        "userinfoQuery": {
          "openid": "@openid"
        },
        "profileMap": {
          "sub": "unionid",
          "name": "nickname",
          "picture": "headimgurl"
        }
      }
    }
  ]
}
