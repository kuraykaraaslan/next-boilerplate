{
  "id": "facebook",
  "name": "Facebook",
  "version": "1.0.0",
  "description": "facebook social login (OAuth2/OIDC), contributed into auth_sso:provider — sandboxed.",
  "icon": "fab fa-facebook",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": [
      "http",
      "secrets"
    ],
    "httpAllowlist": [
      "graph.facebook.com"
    ],
    "limits": {
      "memoryMb": 64,
      "timeoutMs": 30000,
      "httpTimeoutMs": 28000,
      "httpMaxBytes": 2000000
    }
  },
  "config": {
    "secrets": [
      {
        "key": "clientSecret",
        "label": "OAuth Client Secret"
      }
    ]
  },
  "extensions": [
    {
      "point": "auth_sso:provider",
      "key": "facebook",
      "metadata": {
        "label": "Facebook",
        "usesPkce": false,
        "userinfoFields": "id,name,email,first_name,last_name,picture",
        "profileMap": {
          "sub": "id",
          "email": "email",
          "name": "name",
          "firstName": "first_name",
          "lastName": "last_name",
          "picture": "picture.data.url"
        }
      }
    }
  ]
}
