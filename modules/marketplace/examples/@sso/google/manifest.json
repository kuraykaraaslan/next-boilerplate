{
  "id": "google",
  "name": "Google",
  "version": "1.0.0",
  "description": "google social login (OAuth2/OIDC), contributed into auth_sso:provider — sandboxed.",
  "icon": "fab fa-google",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": [
      "http",
      "secrets"
    ],
    "httpAllowlist": [
      "oauth2.googleapis.com",
      "openidconnect.googleapis.com"
    ],
    "limits": {
      "memoryMb": 64,
      "timeoutMs": 30000,
      "httpTimeoutMs": 28000,
      "httpMaxBytes": 2000000
    }
  },
  "config": {
    "secrets": [
      {
        "key": "clientSecret",
        "label": "OAuth Client Secret"
      }
    ]
  },
  "extensions": [
    {
      "point": "auth_sso:provider",
      "key": "google",
      "metadata": {
        "label": "Google",
        "usesPkce": true,
        "profileMap": {
          "sub": "sub",
          "email": "email",
          "emailVerified": "email_verified",
          "name": "name",
          "firstName": "given_name",
          "lastName": "family_name",
          "picture": "picture",
          "locale": "locale"
        }
      }
    }
  ]
}
