{
  "id": "weibo",
  "name": "Weibo",
  "version": "1.0.0",
  "description": "weibo social login (OAuth2/OIDC), contributed into auth_sso:provider — sandboxed.",
  "icon": "fab fa-weibo",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": [
      "http",
      "secrets"
    ],
    "httpAllowlist": [
      "api.weibo.com"
    ],
    "limits": {
      "memoryMb": 64,
      "timeoutMs": 30000,
      "httpTimeoutMs": 28000,
      "httpMaxBytes": 2000000
    }
  },
  "config": {
    "secrets": [
      {
        "key": "clientSecret",
        "label": "OAuth Client Secret"
      }
    ]
  },
  "extensions": [
    {
      "point": "auth_sso:provider",
      "key": "weibo",
      "metadata": {
        "label": "Weibo",
        "usesPkce": false,
        "openidFrom": "uid",
        "userinfoAuth": "query",
        "userinfoQuery": {
          "uid": "@openid"
        },
        "profileMap": {
          "sub": "id",
          "name": "screen_name",
          "picture": "avatar_large"
        }
      }
    }
  ]
}
