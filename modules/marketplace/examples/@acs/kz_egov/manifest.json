{
  "id": "kz_egov",
  "name": "eGov.kz",
  "version": "1.0.0",
  "description": "eGov.kz — national identity (OIDC), contributed into auth_acs:provider, sandboxed.",
  "icon": "fas fa-id-card",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": [
      "http",
      "secrets",
      "crypto"
    ],
    "httpAllowlist": [],
    "limits": {
      "memoryMb": 64,
      "timeoutMs": 30000,
      "httpTimeoutMs": 28000,
      "httpMaxBytes": 2000000
    }
  },
  "config": {
    "secrets": [
      {
        "key": "clientSecret",
        "label": "OIDC Client Secret",
        "help": "Stored encrypted; injected host-side for the token exchange."
      }
    ]
  },
  "extensions": [
    {
      "point": "auth_acs:provider",
      "key": "kz_egov",
      "metadata": {
        "label": "eGov.kz",
        "protocol": "oidc",
        "country": "KZ"
      }
    }
  ]
}
