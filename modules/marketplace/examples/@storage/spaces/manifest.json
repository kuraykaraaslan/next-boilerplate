{
  "id": "digitalocean-spaces",
  "name": "DigitalOcean Spaces Storage",
  "version": "1.0.0",
  "description": "DigitalOcean Spaces (S3-compatible) storage backend, contributed into storage:provider — sandboxed. Path-style SigV4 PutObject/DeleteObject via host crypto; the secret key stays host-side.",
  "icon": "fas fa-database",
  "sandbox": {
    "runtime": "isolated",
    "capabilities": ["http", "settings", "crypto"],
    "httpAllowlist": [],
    "httpAllowlistFromSettings": ["s3Endpoint"],
    "limits": { "memoryMb": 256, "timeoutMs": 60000, "httpTimeoutMs": 58000, "httpMaxBytes": 2000000 }
  },
  "config": {
    "settings": [
      { "key": "s3Bucket", "label": "Space Name", "help": "DigitalOcean Space (bucket) name." },
      { "key": "s3Region", "label": "Region", "help": "Spaces region, e.g. nyc3." },
      { "key": "s3Endpoint", "label": "Endpoint URL", "help": "https://<region>.digitaloceanspaces.com (used for egress + the allowlist)." },
      { "key": "s3AccessKey", "label": "Access Key", "help": "Spaces access key." }
    ],
    "secrets": [
      { "key": "s3SecretKey", "label": "Secret Key", "help": "Spaces secret key; used host-side in the SigV4 chain, never seen by the plugin." }
    ]
  },
  "extensions": [
    { "point": "storage:provider", "key": "digitalocean-spaces", "metadata": { "label": "DigitalOcean Spaces" } }
  ]
}
