{
  "$schema": "../module.schema.json",
  "id": "storage",
  "name": "Storage",
  "description": "File storage and media management",
  "version": "1.0.0",
  "author": "System",
  "icon": "faDatabase",
  "tags": ["storage", "files", "media"],
  "enabled": true,
  "priority": 40,
  "settingKeys": [
    "storageProvider", "s3Bucket", "s3Region", "s3AccessKey", "s3SecretKey", "s3Endpoint",
    "maxFileSizeMb", "allowedExtensions"
  ],
  "settings": {
    "tabs": [
      { "id": "storage", "label": "Storage", "icon": "faDatabase", "component": "ui/storage.settings", "order": 40, "scope": "system" }
    ]
  },
  "permissions": [
    { "id": "storage.view", "name": "View Storage", "group": "storage" },
    { "id": "storage.upload", "name": "Upload Files", "group": "storage" },
    { "id": "storage.delete", "name": "Delete Files", "group": "storage" }
  ]
}
