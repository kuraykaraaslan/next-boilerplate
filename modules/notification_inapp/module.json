{
  "$schema": "../module.schema.json",
  "id": "notification_inapp",
  "name": "In-App Notifications",
  "description": "In-app notification feed with unread counts. Consumed by the notification menu in the app shell.",
  "version": "1.0.0",
  "icon": "fas fa-bell",
  "tags": [
    "notifications",
    "in-app"
  ],
  "priority": 30,
  "dependencies": {
    "requires": [
      "db",
      "user"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/notification_inapp",
  "license": "CC-BY-NC-ND-4.0",
  "apiRoutes": [
    {
      "path": "/api/notifications/push/subscribe",
      "handler": "notification_inapp/server/notifications-push-subscribe.route"
    },
    {
      "path": "/api/notifications/sms/send",
      "handler": "notification_inapp/server/notifications-sms-send.route"
    },
    {
      "path": "/api/auth/me/notifications/stream",
      "handler": "notification_inapp/server/auth-me-notifications-stream.route"
    }
  ]
}
