{
  "$schema": "../module.schema.json",
  "id": "tenant_member",
  "name": "Tenant Member",
  "description": "Tenant-scoped membership join table with roles (owner/admin/member) and per-member permissions.",
  "version": "1.0.0",
  "icon": "fas fa-users",
  "tags": [
    "tenant"
  ],
  "priority": 21,
  "dependencies": {
    "requires": [
      "db",
      "tenant",
      "user"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/tenant_member",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "members",
      "label": "Members",
      "href": "/admin/members",
      "icon": "fas fa-people-group",
      "group": "Management",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/members",
      "component": "tenant_member/ui/members.page"
    },
    {
      "path": "/admin/members/settings",
      "component": "tenant_member/ui/members-settings.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/members/[memberId]",
      "handler": "tenant_member/server/members-member-id.route"
    },
    {
      "path": "/api/members",
      "handler": "tenant_member/server/members.route"
    }
  ]
}
