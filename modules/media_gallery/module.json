{
  "$schema": "../module.schema.json",
  "id": "media_gallery",
  "name": "Media Gallery",
  "description": "Polymorphic ordered image gallery attachable to any entity type. Items wrap UploadedFile rows (storage module) and add gallery-side overlay: sortOrder, isPrimary, altText, title.",
  "version": "1.0.0",
  "icon": "fas fa-images",
  "tags": [
    "media",
    "gallery",
    "images"
  ],
  "priority": 36,
  "dependencies": {
    "requires": [
      "db",
      "redis",
      "storage"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/media_gallery",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "media-library",
      "label": "Media Library",
      "href": "/admin/media",
      "icon": "fas fa-images",
      "group": "Media",
      "workspace": "content",
      "order": 20,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/media",
      "component": "media_gallery/ui/media-library.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/media-gallery/[entityType]/[entityId]/items/reorder",
      "handler": "media_gallery/server/media-gallery-entity-type-entity-id-items-reorder.route"
    },
    {
      "path": "/api/media-gallery/[entityType]/[entityId]/items",
      "handler": "media_gallery/server/media-gallery-entity-type-entity-id-items.route"
    },
    {
      "path": "/api/media-gallery/items/[itemId]",
      "handler": "media_gallery/server/media-gallery-items-item-id.route"
    }
  ]
}
