{
  "$schema": "../module.schema.json",
  "id": "coupon",
  "name": "Coupon",
  "description": "Discount coupons + redemption tracking. Provider-aware (Stripe / PayPal / Iyzico) so codes sync with the payment processor.",
  "version": "1.0.0",
  "icon": "fas fa-ticket",
  "tags": [
    "billing",
    "marketing"
  ],
  "priority": 26,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "payment",
      "common"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/coupon",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "coupons",
      "label": "Coupons",
      "href": "/admin/coupons",
      "icon": "fas fa-key",
      "group": "Commerce",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/coupons/[couponId]",
      "component": "coupon/ui/coupons-coupon-id.page"
    },
    {
      "path": "/admin/coupons",
      "component": "coupon/ui/coupons.page"
    }
  ]
}
