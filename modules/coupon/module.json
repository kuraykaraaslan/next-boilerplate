{
  "$schema": "../module.schema.json",
  "id": "coupon",
  "name": "Coupon",
  "description": "Discount coupons + redemption tracking. Validation and discount are computed locally (the code is the single source of truth); at checkout the discount is turned into gateway params via the payment:coupon extension point (Stripe / PayPal / Iyzico) — nothing is synced to the processor's coupon registry.",
  "version": "1.0.0",
  "icon": "fas fa-ticket",
  "tags": [
    "billing",
    "marketing"
  ],
  "priority": 26,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "payment",
      "common"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/coupon",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "coupons",
      "label": "Coupons",
      "href": "/admin/coupons",
      "icon": "fas fa-key",
      "group": "Commerce",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/coupons/[couponId]",
      "component": "coupon/ui/coupons-coupon-id.page"
    },
    {
      "path": "/admin/coupons",
      "component": "coupon/ui/coupons.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/coupons/[couponId]",
      "handler": "coupon/server/coupons-coupon-id.route"
    },
    {
      "path": "/api/coupons/apply",
      "handler": "coupon/server/coupons-apply.route"
    },
    {
      "path": "/api/coupons/redemptions",
      "handler": "coupon/server/coupons-redemptions.route"
    },
    {
      "path": "/api/coupons",
      "handler": "coupon/server/coupons.route"
    },
    {
      "path": "/api/coupons/validate",
      "handler": "coupon/server/coupons-validate.route"
    }
  ]
}
