{
  "$schema": "../module.schema.json",
  "id": "feature_flags",
  "name": "Feature Flags",
  "description": "Tenant-scoped feature flags with master switch, deterministic percentage rollout, attribute-based targeting rules, and per-subject (user/segment) overrides. Read-through cached for hot-path evaluation; every write is audit-logged.",
  "version": "1.0.0",
  "icon": "fas fa-toggle-on",
  "tags": [
    "platform",
    "feature-flags",
    "rollout",
    "experimentation"
  ],
  "priority": 48,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "redis",
      "common",
      "audit_log"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/feature_flags",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "feature-flags",
      "label": "Feature Flags",
      "href": "/admin/feature-flags",
      "icon": "fas fa-toggle-on",
      "group": "Insights",
      "workspace": "crm",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/feature-flags",
      "component": "feature_flags/ui/feature-flags.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/feature-flags/[key]/overrides/[overrideId]",
      "handler": "feature_flags/server/feature-flags-key-overrides-override-id.route"
    },
    {
      "path": "/api/feature-flags/[key]/overrides",
      "handler": "feature_flags/server/feature-flags-key-overrides.route"
    },
    {
      "path": "/api/feature-flags/[key]",
      "handler": "feature_flags/server/feature-flags-key.route"
    },
    {
      "path": "/api/feature-flags/evaluate",
      "handler": "feature_flags/server/feature-flags-evaluate.route"
    },
    {
      "path": "/api/feature-flags",
      "handler": "feature_flags/server/feature-flags.route"
    }
  ]
}
