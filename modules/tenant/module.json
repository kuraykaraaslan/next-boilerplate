{
  "$schema": "../module.schema.json",
  "id": "tenant",
  "name": "Tenant",
  "description": "Tenant CRUD, lifecycle (active/suspended/deleted), soft-deletion service. Foundation of multi-tenancy.",
  "version": "1.0.0",
  "icon": "fas fa-building",
  "tags": [
    "tenant",
    "core"
  ],
  "priority": 20,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "logger",
      "common"
    ]
  },
  "settings": {
    "keys": "TENANT_KEYS"
  },
  "settingKeys": [
    "TENANT_KEYS"
  ],
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/tenant",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "platform-tenants",
      "label": "Tenants",
      "href": "/admin/tenants",
      "icon": "fas fa-building",
      "group": "Platform",
      "order": 10,
      "scope": "system"
    }
  ],
  "routes": [
    {
      "path": "/admin/tenants/[targetTenantId]",
      "component": "tenant/ui/tenants-target-tenant-id.page"
    },
    {
      "path": "/admin/tenants",
      "component": "tenant/ui/tenants.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/tenants/[targetTenantId]/deletion-request",
      "handler": "tenant/server/tenants-target-tenant-id-deletion-request.route"
    },
    {
      "path": "/api/tenants/[targetTenantId]",
      "handler": "tenant/server/tenants-target-tenant-id.route"
    },
    {
      "path": "/api/tenants/[targetTenantId]/subscription",
      "handler": "tenant/server/tenants-target-tenant-id-subscription.route"
    },
    {
      "path": "/api/tenants/create",
      "handler": "tenant/server/tenants-create.route"
    },
    {
      "path": "/api/tenants",
      "handler": "tenant/server/tenants.route"
    },
    {
      "path": "/api/cron/purge-expired-tenants",
      "handler": "tenant/server/cron-purge-expired-tenants.route"
    }
  ]
}
