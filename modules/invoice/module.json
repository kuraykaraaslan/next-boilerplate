{
  "$schema": "../module.schema.json",
  "id": "invoice",
  "name": "Invoice",
  "description": "Tenant-scoped invoicing with regional e-invoicing adapters (TR e-Arşiv, EU Peppol, US Stripe Tax). Each tenant issues its own invoices keyed to its own subscription / payment flow.",
  "version": "1.0.0",
  "icon": "fas fa-file-invoice",
  "tags": [
    "invoice",
    "billing",
    "compliance",
    "tax"
  ],
  "priority": 30,
  "dependencies": {
    "requires": [
      "db",
      "tenant",
      "setting",
      "audit_log",
      "tenant_subscription",
      "payment",
      "notification_mail"
    ]
  },
  "settingKeys": [
    "INVOICE_KEYS"
  ],
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/invoice",
  "license": "CC-BY-NC-ND-4.0",
  "extensionPoints": [
    {
      "id": "invoice:adapter",
      "kind": "provider",
      "description": "A regional/country e-invoicing adapter (UBL-TR/GİB, Peppol BIS, FatturaPA, Chorus Pro, ZUGFeRD, CFDI, GST IRP, US Stripe Tax). Satellite modules like invoice_tr_earsiv contribute their adapter here; the host's adapters/registry discovers them via the extension registry. Routing (region vs issuer-country) is carried in each contribution's metadata { kind, code }. Shared XML helpers (xml.util, cii_xml) and the InvoiceAdapter contract stay in the host."
    }
  ],
  "routes": [
    {
      "path": "/admin/invoices/[invoiceId]",
      "component": "invoice/ui/invoices-invoice-id.page"
    },
    {
      "path": "/admin/invoices",
      "component": "invoice/ui/invoices.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/invoices/[invoiceId]/issue",
      "handler": "invoice/server/invoices-invoice-id-issue.route"
    },
    {
      "path": "/api/invoices/[invoiceId]/mark-paid",
      "handler": "invoice/server/invoices-invoice-id-mark-paid.route"
    },
    {
      "path": "/api/invoices/[invoiceId]/pdf",
      "handler": "invoice/server/invoices-invoice-id-pdf.route"
    },
    {
      "path": "/api/invoices/[invoiceId]",
      "handler": "invoice/server/invoices-invoice-id.route"
    },
    {
      "path": "/api/invoices/[invoiceId]/void",
      "handler": "invoice/server/invoices-invoice-id-void.route"
    },
    {
      "path": "/api/invoices/earsiv/sms/send",
      "handler": "invoice/server/invoices-earsiv-sms-send.route"
    },
    {
      "path": "/api/invoices/earsiv/sms/verify",
      "handler": "invoice/server/invoices-earsiv-sms-verify.route"
    },
    {
      "path": "/api/invoices/preview",
      "handler": "invoice/server/invoices-preview.route"
    },
    {
      "path": "/api/invoices",
      "handler": "invoice/server/invoices.route"
    }
  ]
}
