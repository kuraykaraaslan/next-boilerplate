{
  "$schema": "../module.schema.json",
  "id": "audit_log",
  "name": "Audit Log",
  "description": "Append-only audit trail for sensitive actions, stored per-tenant (platform events land on ROOT_TENANT_ID).",
  "version": "1.0.0",
  "icon": "fas fa-clipboard-list",
  "tags": [
    "platform",
    "security",
    "compliance"
  ],
  "priority": 40,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "logger",
      "common",
      "redis",
      "setting",
      "webhook",
      "tenant"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/audit_log",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "platform-audit-logs",
      "label": "Audit Logs",
      "href": "/admin/audit-logs",
      "icon": "fas fa-clock-rotate-left",
      "group": "Platform",
      "order": 10,
      "scope": "system"
    }
  ],
  "routes": [
    {
      "path": "/admin/audit-logs",
      "component": "audit_log/ui/audit-logs.page"
    },
    {
      "path": "/admin/audit-logs/settings",
      "component": "audit_log/ui/audit-logs-settings.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/audit-logs/anonymize",
      "handler": "audit_log/server/audit-logs-anonymize.route"
    },
    {
      "path": "/api/audit-logs/cross-tenant",
      "handler": "audit_log/server/audit-logs-cross-tenant.route"
    },
    {
      "path": "/api/audit-logs/export",
      "handler": "audit_log/server/audit-logs-export.route"
    },
    {
      "path": "/api/audit-logs/purge",
      "handler": "audit_log/server/audit-logs-purge.route"
    },
    {
      "path": "/api/audit-logs",
      "handler": "audit_log/server/audit-logs.route"
    },
    {
      "path": "/api/audit-logs/verify",
      "handler": "audit_log/server/audit-logs-verify.route"
    }
  ]
}
