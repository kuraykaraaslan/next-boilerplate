{
  "$schema": "../module.schema.json",
  "id": "webhook",
  "name": "Outgoing Webhooks",
  "description": "Subscriber-configured outbound webhooks (tenant-scoped; root tenant carries platform-wide events), signed deliveries, retry+redelivery.",
  "version": "1.0.0",
  "icon": "fas fa-rss",
  "tags": [
    "platform",
    "integration"
  ],
  "priority": 40,
  "dependencies": {
    "requires": [
      "db",
      "redis",
      "env"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/webhook",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "webhooks",
      "label": "Webhooks",
      "href": "/admin/webhooks",
      "icon": "fas fa-plug",
      "group": "Developer",
      "workspace": "developer",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/webhooks",
      "component": "webhook/ui/webhooks.page"
    },
    {
      "path": "/admin/webhooks/settings",
      "component": "webhook/ui/webhooks-settings.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/webhooks/[webhookId]/deliveries/[deliveryId]/redeliver",
      "handler": "webhook/server/webhooks-webhook-id-deliveries-delivery-id-redeliver.route"
    },
    {
      "path": "/api/webhooks/[webhookId]/deliveries/replay-dead-letter",
      "handler": "webhook/server/webhooks-webhook-id-deliveries-replay-dead-letter.route"
    },
    {
      "path": "/api/webhooks/[webhookId]/deliveries",
      "handler": "webhook/server/webhooks-webhook-id-deliveries.route"
    },
    {
      "path": "/api/webhooks/[webhookId]/rotate-secret",
      "handler": "webhook/server/webhooks-webhook-id-rotate-secret.route"
    },
    {
      "path": "/api/webhooks/[webhookId]",
      "handler": "webhook/server/webhooks-webhook-id.route"
    },
    {
      "path": "/api/webhooks/[webhookId]/test",
      "handler": "webhook/server/webhooks-webhook-id-test.route"
    },
    {
      "path": "/api/webhooks/[webhookId]/trigger",
      "handler": "webhook/server/webhooks-webhook-id-trigger.route"
    },
    {
      "path": "/api/webhooks/events",
      "handler": "webhook/server/webhooks-events.route"
    },
    {
      "path": "/api/webhooks/metrics",
      "handler": "webhook/server/webhooks-metrics.route"
    },
    {
      "path": "/api/webhooks",
      "handler": "webhook/server/webhooks.route"
    }
  ]
}
