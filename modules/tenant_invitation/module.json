{
  "$schema": "../module.schema.json",
  "id": "tenant_invitation",
  "name": "Tenant Invitation",
  "description": "Email invitation flow: create / accept / decline / revoke. Bound to tenant_member on acceptance.",
  "version": "1.0.0",
  "icon": "fas fa-envelope-open",
  "tags": [
    "tenant",
    "onboarding"
  ],
  "priority": 22,
  "dependencies": {
    "requires": [
      "db",
      "tenant",
      "tenant_member",
      "notification_mail",
      "user",
      "env"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/tenant_invitation",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "invitations",
      "label": "Invitations",
      "href": "/admin/invitations",
      "icon": "fas fa-envelope",
      "group": "Management",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/invitations",
      "component": "tenant_invitation/ui/invitations.page"
    },
    {
      "path": "/admin/invitations/settings",
      "component": "tenant_invitation/ui/invitations-settings.page"
    }
  ]
}
