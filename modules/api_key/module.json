{
  "$schema": "../module.schema.json",
  "id": "api_key",
  "name": "API Key",
  "description": "Tenant-scoped API keys for programmatic access (hashed at rest, scope-bound).",
  "version": "1.0.0",
  "icon": "fas fa-key",
  "tags": [
    "platform",
    "security"
  ],
  "priority": 40,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "common",
      "network"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/api_key",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "api-keys",
      "label": "API Keys",
      "href": "/admin/api-keys",
      "icon": "fas fa-key",
      "group": "Developer",
      "workspace": "developer",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/api-keys",
      "component": "api_key/ui/api-keys.page"
    },
    {
      "path": "/admin/api-keys/settings",
      "component": "api_key/ui/api-keys-settings.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/api-keys/[apiKeyId]/rotate",
      "handler": "api_key/server/api-keys-api-key-id-rotate.route"
    },
    {
      "path": "/api/api-keys/[apiKeyId]",
      "handler": "api_key/server/api-keys-api-key-id.route"
    },
    {
      "path": "/api/api-keys/revoke-all",
      "handler": "api_key/server/api-keys-revoke-all.route"
    },
    {
      "path": "/api/api-keys",
      "handler": "api_key/server/api-keys.route"
    },
    {
      "path": "/api/api-keys/sweep-expired",
      "handler": "api_key/server/api-keys-sweep-expired.route"
    },
    {
      "path": "/api/api-keys/verify",
      "handler": "api_key/server/api-keys-verify.route"
    }
  ]
}
