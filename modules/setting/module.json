{
  "$schema": "../module.schema.json",
  "id": "setting",
  "name": "Settings",
  "description": "Core settings management module",
  "version": "1.0.0",
  "author": "System",
  "icon": "faCog",
  "tags": ["core", "settings"],
  "enabled": true,
  "priority": 0,
  "settingKeys": [
    "siteName", "siteUrl", "siteDescription", "logoUrl", "faviconUrl",
    "applicationHost", "applicationDomain", "i18nLanguages",
    "contactName", "contactTitle", "contactEmail", "contactPhone",
    "maintenanceMode", "maintenanceMessage",
    "discordWebhookUrl", "discordDoormanWebhookUrl", "githubTreeUrl", "githubToken", "githubUser",
    "googleTagId",
    "facebookUrl", "twitterUrl", "instagramUrl", "linkedinUrl", "youtubeUrl", "githubProfileUrl", "tiktokUrl", "pinterestUrl",
    "defaultTimezone", "defaultLanguage", "dateFormat", "timeFormat", "datetimeFormat", "weekStartsOn", "currencySymbol", "currencyPosition", "thousandSeparator", "decimalSeparator"
  ],
  "settings": {
    "tabs": [
      { "id": "general", "label": "General", "icon": "faCog", "component": "ui/general.settings", "order": 0, "scope": "system" },
      { "id": "security", "label": "Security", "icon": "faShield", "component": "ui/security.settings", "order": 60, "scope": "system" },
      { "id": "integrations", "label": "Integrations", "icon": "faPlug", "component": "ui/integrations.settings", "order": 70, "scope": "system" },
      { "id": "analytics", "label": "Analytics", "icon": "faChartLine", "component": "ui/analytics.settings", "order": 80, "scope": "system" },
      { "id": "social", "label": "Social", "icon": "faShareNodes", "component": "ui/social.settings", "order": 90, "scope": "system" },
      { "id": "notifications", "label": "Notifications", "icon": "faBell", "component": "ui/notification.settings", "order": 110, "scope": "system" },
      { "id": "localization", "label": "Localization", "icon": "faGlobe", "component": "ui/localization.settings", "order": 120, "scope": "system" }
    ]
  },
  "menu": [
    { "id": "home", "label": "Home", "href": "/system/admin", "icon": "faHome", "order": 0, "scope": "system" },
    { "id": "settings", "label": "Settings", "href": "/system/admin/settings", "icon": "faCog", "order": 900, "scope": "system" }
  ],
  "permissions": [
    { "id": "settings.view", "name": "View Settings", "group": "settings" },
    { "id": "settings.edit", "name": "Edit Settings", "group": "settings" }
  ]
}
