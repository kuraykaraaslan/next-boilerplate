{
  "$schema": "../module.schema.json",
  "id": "payment",
  "name": "Payment",
  "description": "Pluggable payment processing (Stripe, PayPal, Iyzico) + subscription plans, plan features, payment transactions, webhook handling.",
  "version": "1.0.0",
  "icon": "fas fa-credit-card",
  "tags": [
    "billing",
    "payment"
  ],
  "priority": 25,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "setting",
      "common"
    ]
  },
  "settings": {
    "keys": "PAYMENT_KEYS"
  },
  "settingKeys": [
    "PAYMENT_KEYS"
  ],
  "menu": [
    {
      "id": "plans",
      "label": "Plans",
      "href": "/admin/plans",
      "icon": "fas fa-credit-card",
      "group": "Commerce",
      "order": 10,
      "scope": "tenant"
    },
    {
      "id": "payments",
      "label": "Payments",
      "href": "/admin/payments",
      "icon": "fas fa-credit-card",
      "group": "Commerce",
      "order": 11,
      "scope": "tenant"
    },
    {
      "id": "invoices",
      "label": "Invoices",
      "href": "/admin/invoices",
      "icon": "fas fa-file-invoice",
      "group": "Commerce",
      "order": 12,
      "scope": "tenant"
    }
  ],
  "slots": [
    {
      "slot": "user.profile.tabs",
      "component": "payment/ui/billing-profile-tab.component",
      "order": 50,
      "scope": "both",
      "props": {
        "label": "Billing"
      }
    }
  ],
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/payment",
  "license": "CC-BY-NC-ND-4.0",
  "routes": [
    {
      "path": "/admin/payments/[paymentId]",
      "component": "payment/ui/payments-payment-id.page"
    },
    {
      "path": "/admin/payments",
      "component": "payment/ui/payments.page"
    },
    {
      "path": "/admin/payments/settings",
      "component": "payment/ui/payments-settings.page"
    },
    {
      "path": "/admin/plans/[planId]",
      "component": "payment/ui/plans-plan-id.page"
    },
    {
      "path": "/admin/plans",
      "component": "payment/ui/plans.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/checkout/agreements/accept",
      "handler": "payment/server/checkout-agreements-accept.route"
    },
    {
      "path": "/api/checkout/agreements",
      "handler": "payment/server/checkout-agreements.route"
    },
    {
      "path": "/api/payments/[paymentId]/refund",
      "handler": "payment/server/payments-payment-id-refund.route"
    },
    {
      "path": "/api/payments/[paymentId]",
      "handler": "payment/server/payments-payment-id.route"
    },
    {
      "path": "/api/payments/[paymentId]/transactions",
      "handler": "payment/server/payments-payment-id-transactions.route"
    },
    {
      "path": "/api/payments/bin-check",
      "handler": "payment/server/payments-bin-check.route"
    },
    {
      "path": "/api/payments/provider-status",
      "handler": "payment/server/payments-provider-status.route"
    },
    {
      "path": "/api/payments/providers",
      "handler": "payment/server/payments-providers.route"
    },
    {
      "path": "/api/payments",
      "handler": "payment/server/payments.route"
    },
    {
      "path": "/api/payments/transactions/[transactionId]",
      "handler": "payment/server/payments-transactions-transaction-id.route"
    },
    {
      "path": "/api/payments/wallets",
      "handler": "payment/server/payments-wallets.route"
    },
    {
      "path": "/api/plans/[planId]/features/[featureId]",
      "handler": "payment/server/plans-plan-id-features-feature-id.route"
    },
    {
      "path": "/api/plans/[planId]/features",
      "handler": "payment/server/plans-plan-id-features.route"
    },
    {
      "path": "/api/plans/[planId]",
      "handler": "payment/server/plans-plan-id.route"
    },
    {
      "path": "/api/plans/default",
      "handler": "payment/server/plans-default.route"
    },
    {
      "path": "/api/plans/public",
      "handler": "payment/server/plans-public.route"
    },
    {
      "path": "/api/plans",
      "handler": "payment/server/plans.route"
    }
  ],
  "extensionPoints": [
    {
      "id": "payment:gateway",
      "kind": "provider",
      "description": "A payment gateway implementation (Stripe, PayPal, Iyzico, ...). Satellite modules like payment_stripe contribute their gateway here; the host discovers them via the extension registry."
    }
  ]
}
