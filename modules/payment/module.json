{
  "$schema": "../module.schema.json",
  "id": "payment",
  "name": "Payment",
  "description": "Payment processing and billing",
  "version": "1.0.0",
  "author": "System",
  "icon": "faCreditCard",
  "tags": ["payment", "billing"],
  "enabled": true,
  "priority": 50,
  "settingKeys": [
    "stripeEnabled", "stripePublicKey", "stripeSecretKey", "stripeWebhookSecret",
    "paypalEnabled", "paypalClientId", "paypalClientSecret", "paypalSandboxMode",
    "iyzicoEnabled", "iyzicoApiKey", "iyzicoSecretKey", "iyzicoSandboxMode",
    "currency", "taxRate", "taxEnabled",
    "billingEmail", "billingName", "billingAddress",
    "taxId", "vatNumber",
    "invoicePrefix", "invoiceFooter"
  ],
  "settings": {
    "tabs": [
      { "id": "payment", "label": "Payment", "icon": "faCreditCard", "component": "ui/payment.settings", "order": 100, "scope": "system" },
      { "id": "billing", "label": "Billing", "icon": "faCreditCard", "component": "ui/payment.tenant", "order": 60, "scope": "tenant" }
    ]
  },
  "permissions": [
    { "id": "payment.view", "name": "View Payments", "group": "payment" },
    { "id": "payment.manage", "name": "Manage Payments", "group": "payment" },
    { "id": "billing.view", "name": "View Billing", "group": "billing" },
    { "id": "billing.manage", "name": "Manage Billing", "group": "billing" }
  ]
}
