{
  "$schema": "../module.schema.json",
  "id": "metering",
  "name": "Metering",
  "description": "Event-based usage metering with metered / overage billing. Records immutable usage events per meter (SUM/MAX/LAST aggregation), keeps a Redis hot counter for fast current-period reads, and settles overages on a two-rail model: prepaid wallet credits are debited first, the remainder is invoiced as a draft. Quantities and money are integer minor units; runs are idempotent and persisted.",
  "version": "1.0.0",
  "icon": "fas fa-gauge-high",
  "tags": [
    "metering",
    "usage",
    "billing",
    "overage",
    "credits"
  ],
  "priority": 48,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "logger",
      "common",
      "redis",
      "wallet",
      "invoice",
      "tenant_subscription",
      "webhook",
      "audit_log"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/metering",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "metering",
      "label": "Metering",
      "href": "/admin/metering",
      "icon": "fas fa-gauge-high",
      "group": "Commerce",
      "workspace": "commerce",
      "order": 10,
      "scope": "tenant"
    },
    {
      "id": "metering-settings",
      "label": "Settings",
      "href": "/admin/metering/settings",
      "icon": "fas fa-gear",
      "group": "Configuration",
      "workspace": "commerce",
      "order": 90,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/metering",
      "component": "metering/ui/metering.page"
    },
    {
      "path": "/admin/metering/runs/[runId]",
      "component": "metering/ui/metering-runs-run-id.page"
    },
    {
      "path": "/admin/metering/settings",
      "component": "metering/ui/metering-settings.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/metering/billing",
      "handler": "metering/server/metering-billing.route"
    },
    {
      "path": "/api/metering/runs",
      "handler": "metering/server/metering-runs.route"
    },
    {
      "path": "/api/metering/runs/[runId]",
      "handler": "metering/server/metering-runs-run-id.route"
    },
    {
      "path": "/api/metering/runs/[runId]/lines",
      "handler": "metering/server/metering-runs-run-id-lines.route"
    },
    {
      "path": "/api/metering/runs/[runId]/calculate",
      "handler": "metering/server/metering-runs-run-id-calculate.route"
    },
    {
      "path": "/api/metering/runs/[runId]/bill",
      "handler": "metering/server/metering-runs-run-id-bill.route"
    },
    {
      "path": "/api/metering/events",
      "handler": "metering/server/metering-events.route"
    },
    {
      "path": "/api/metering/meters/[meterId]",
      "handler": "metering/server/metering-meters-meter-id.route"
    },
    {
      "path": "/api/metering/meters",
      "handler": "metering/server/metering-meters.route"
    },
    {
      "path": "/api/metering/usage",
      "handler": "metering/server/metering-usage.route"
    }
  ]
}
