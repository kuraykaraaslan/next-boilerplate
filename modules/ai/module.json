{
  "$schema": "../module.schema.json",
  "id": "ai",
  "name": "AI",
  "description": "Pluggable AI providers (Anthropic, OpenAI, Google). Chat, embeddings, streaming, usage tracking.",
  "version": "1.0.0",
  "icon": "fas fa-robot",
  "tags": [
    "platform",
    "ai"
  ],
  "priority": 50,
  "dependencies": {
    "requires": [
      "env",
      "setting"
    ]
  },
  "settings": {
    "keys": "AI_KEYS"
  },
  "settingKeys": [
    "AI_KEYS"
  ],
  "extensionPoints": [
    {
      "id": "ai:provider",
      "kind": "provider",
      "description": "A backend AI provider (chat / embeddings / streaming). Satellite modules like ai_openai contribute their implementation here."
    }
  ],
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/ai",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "ai",
      "label": "AI",
      "href": "/admin/ai",
      "icon": "fas fa-robot",
      "group": "Developer",
      "order": 10,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/ai",
      "component": "ai/ui/ai.page"
    },
    {
      "path": "/admin/ai/settings",
      "component": "ai/ui/settings.page"
    }
  ],
  "apiRoutes": [
    {
      "path": "/api/ai/chat",
      "handler": "ai/server/ai-chat.route"
    },
    {
      "path": "/api/ai/embed",
      "handler": "ai/server/ai-embed.route"
    },
    {
      "path": "/api/ai/models",
      "handler": "ai/server/ai-models.route"
    },
    {
      "path": "/api/ai/providers",
      "handler": "ai/server/ai-providers.route"
    },
    {
      "path": "/api/ai/usage",
      "handler": "ai/server/ai-usage.route"
    },
    {
      "path": "/api/ai/stream",
      "handler": "ai/server/ai-stream.route"
    }
  ]
}
