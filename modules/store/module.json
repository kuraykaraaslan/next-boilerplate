{
  "$schema": "../module.schema.json",
  "id": "store",
  "name": "Store",
  "description": "Tenant-aware e-commerce store. Hierarchical categories with typed spec templates; products with Tiptap richtext descriptions, spec values, multiple images, tags, SEO; variation types (Color, Size, …) with options and swatches; product variants with independent SKU / price / stock per combination; product bundles with per-item quantity and price overrides. Admin-only — no storefront UI layer.",
  "version": "1.0.0",
  "icon": "fas fa-store",
  "tags": [
    "store",
    "ecommerce",
    "products",
    "catalog"
  ],
  "priority": 40,
  "dependencies": {
    "requires": [
      "db",
      "env",
      "redis",
      "logger"
    ]
  },
  "author": "Kuray Karaaslan",
  "homepage": "https://github.com/kuraykaraaslan/next-boilerplate/tree/main/modules/store",
  "license": "CC-BY-NC-ND-4.0",
  "menu": [
    {
      "id": "store-categories",
      "label": "Categories",
      "href": "/admin/store/categories",
      "icon": "fas fa-tag",
      "group": "Store",
      "order": 10,
      "scope": "tenant"
    },
    {
      "id": "store-products",
      "label": "Products",
      "href": "/admin/store/products",
      "icon": "fas fa-box-open",
      "group": "Store",
      "order": 20,
      "scope": "tenant"
    },
    {
      "id": "store-bundles",
      "label": "Bundles",
      "href": "/admin/store/bundles",
      "icon": "fas fa-layer-group",
      "group": "Store",
      "order": 30,
      "scope": "tenant"
    }
  ],
  "routes": [
    {
      "path": "/admin/store/bundles/[bundleId]",
      "component": "store/ui/store-bundles-bundle-id.page"
    },
    {
      "path": "/admin/store/bundles",
      "component": "store/ui/store-bundles.page"
    },
    {
      "path": "/admin/store/categories/[categoryId]",
      "component": "store/ui/store-categories-category-id.page"
    },
    {
      "path": "/admin/store/categories",
      "component": "store/ui/store-categories.page"
    },
    {
      "path": "/admin/store/products/[productId]",
      "component": "store/ui/store-products-product-id.page"
    },
    {
      "path": "/admin/store/products",
      "component": "store/ui/store-products.page"
    }
  ]
}
