{
  "name": "next-boilerplate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typeorm": "ts-node ./node_modules/typeorm/cli",
    "typeorm:migrate": "npm run typeorm migration:run -- -d libs/typeorm/index.ts",
    "typeorm:generate": "npm run typeorm -- -d libs/typeorm/index.ts migration:generate ./migrations/$npm_config_name",
    "typeorm:revert": "npm run typeorm -- -d libs/typeorm/index.ts migration:revert"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.66.5",
    "countries-and-timezones": "^3.8.0",
    "dotenv": "^17.2.3",
    "ejs": "^4.0.1",
    "google-libphonenumber": "^3.2.43",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.2",
    "nodemailer": "^7.0.12",
    "otplib": "^12.0.1",
    "pg": "^8.17.1",
    "qs": "^6.14.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^5.5.6",
    "react-i18next": "^16.5.3",
    "react-phone-number-input": "^3.4.14",
    "react-toastify": "^11.0.5",
    "typeorm": "^0.4.0-alpha.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/ejs": "^3.1.5",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.29",
    "@types/nodemailer": "^7.0.5",
    "@types/pg": "^8.16.0",
    "@types/qs": "^6.14.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.2",
    "prisma": "^7.2.0",
    "tailwindcss": "^4",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5"
  }
}
